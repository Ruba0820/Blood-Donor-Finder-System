# Copy this file to ".env" and fill in your real values. Never commit the real .env file.

# Server
PORT=3000

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=lifedrop

# JWT secret for login tokens (use a long random string in production)
JWT_SECRET=replace_this_with_a_long_random_string

# Key required to use the Admin page (edit/delete donors).
# Change this to your own secret before deploying anywhere public.
ADMIN_KEY=admin123
